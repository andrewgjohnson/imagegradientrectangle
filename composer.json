{
    "name": "andrewgjohnson/imagegradientrectangle",
    "type": "library",
    "description": "imagegradientrectangle is a function that will draw a gradient filled rectangle on your PHP GD images",
    "keywords": [
        "gd",
        "graphics",
        "image",
        "images"
    ],
    "homepage": "https://imagegradientrectangle.agjgd.org",
    "license": "MIT",
    "authors": [
        {
            "name": "Andrew G Johnson",
            "email": "andrew@andrewgjohnson.com",
            "homepage": "https://www.andrewgjohnson.com/",
            "role": "Project Lead"
        }
    ],
    "require": {
        "php": ">=5.0.0",
        "ext-gd": "*",
        "andrewgjohnson/imageblendedcolorallocate": "1.*"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpunit/phpunit": "^12.5",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "autoload": {
        "files": [
            "source/imagegradientrectangle.php"
        ]
    },
    "scripts": {
        "build": "curl -o examples/dependencies/imageblendedcolorallocate.php https://raw.githubusercontent.com/andrewgjohnson/imageblendedcolorallocate/1ed92d79a66fd3562af3fc9b71468725a8569db8/source/imageblendedcolorallocate.php",
        "lint": "@php vendor/bin/phpcs",
        "lint:fix": "@php vendor/bin/phpcbf",
        "phpunit": "@php vendor/bin/phpunit",
        "test": [
            "@lint",
            "@phpunit"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
